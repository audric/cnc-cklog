[Unit]
Description=CNC log ingestion daemon
After=network.target

[Service]
Type=simple
User=cklogd
ExecStart=/usr/local/bin/cklogd -config /etc/cklogd/cklogd.ini
Restart=on-failure
RestartSec=5

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/cklogd
ReadOnlyPaths=/var/log/cnclogs /etc/cklogd

[Install]
WantedBy=multi-user.target
