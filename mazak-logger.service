[Unit]
Description=Mazak DPRNT log forwarder
After=network.target

[Service]
Type=simple
User=cklogd
ExecStart=/usr/local/bin/mazak-logger -config /etc/cklogd/cklogd.ini
Restart=on-failure
RestartSec=5

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/log/cnclogs
ReadOnlyPaths=/etc/cklogd /mnt/mazak

[Install]
WantedBy=multi-user.target
